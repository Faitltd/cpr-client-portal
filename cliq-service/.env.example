ZOHO_CLIENT_SECRET=<<SELF_CLIENT_SECRET>>
ZOHO_REFRESH_TOKEN=1000.694cc5e119d2c3c9e773e9d97452f39f.14e943f91579d216ed81ccc2f4712e90
ZOHO_API_DOMAIN=https://www.zohoapis.com
JWT_SECRET=<<random-32-char>>
PORT=3001
ALLOWED_ORIGINS=https://portal.cpr-renovations.com
# Set to true to allow ensureChannel to create missing Cliq channels automatically.
# Leave false (default) in production to prevent accidental channel creation.
ALLOW_CHANNEL_CREATE=false
# Path to the SQLite database used as a message cache/audit log.
# The directory will be created automatically if it does not exist.
SQLITE_DB_PATH=./data/messages.db
# How often (ms) the server polls Zoho Cliq for new messages to broadcast via WebSocket.
POLL_INTERVAL_MS=5000
# How many recent messages to fetch from Cliq on each poll cycle.
POLL_HISTORY_LIMIT=20
# Directory for shared file uploads.
UPLOAD_DIR=./data/uploads
# Max uploaded file size in megabytes.
MAX_FILE_SIZE_MB=10
